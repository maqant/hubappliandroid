# Product Blueprint Hub

## Environment Variables

# Model Provider: "fake" (default, no API key needed) | "openai" | "azure"
MODEL_PROVIDER=fake

# OpenAI (only when MODEL_PROVIDER=openai)
OPENAI_API_KEY=

# Azure OpenAI (only when MODEL_PROVIDER=azure)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_AUTH_MODE=

# Model IDs (leave empty for defaults)
MODEL_SOL_ID=
MODEL_TERRA_ID=
MODEL_LUNA_ID=

# Budget
MODEL_BUDGET_DEFAULT=
